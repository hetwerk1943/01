# Environment variables – copy this file to .env and fill in values
# NEVER commit the actual .env file to version control.

# PostgreSQL
POSTGRES_DB=saas_db
POSTGRES_USER=saas_user
POSTGRES_PASSWORD=saas_pass

# JWT (CHANGE IN PRODUCTION!)
JWT_SECRET=your_super_secret_jwt_key_change_me
JWT_EXPIRES_IN=7d

# Password reset token TTL in minutes
RESET_TOKEN_TTL_MINUTES=60

# URL of the client (used in password reset emails)
CLIENT_ORIGIN=http://localhost

# SMTP (use real values or an ethereal.email test account)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
MAIL_FROM=noreply@saas-app.example.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
