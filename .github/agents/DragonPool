import os

# ================= KONFIGURACJA =================
repo_name = "cvd-azure-project"
azure_function_name = "cvd-function-app"

# ================= STRUKTURA KATALOGÓW =================
folders = [
    f"{repo_name}/.github/workflows",
    f"{repo_name}/CVD_Function",
    f"{repo_name}/html",
]

for folder in folders:
    os.makedirs(folder, exist_ok=True)

# ================= main.yml =================
main_yml = f"""name: Deploy Azure Function App

on:
  push:
    branches:
      - main

env:
  AZURE_FUNCTIONAPP_NAME: {azure_function_name}
  AZURE_FUNCTIONAPP_PACKAGE_PATH: './CVD_Function'

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Deploy to Azure Functions
        uses: Azure/functions-action@v1
        with:
          app-name: ${{{{ env.AZURE_FUNCTIONAPP_NAME }}}}
          package: ${{{{ env.AZURE_FUNCTIONAPP_PACKAGE_PATH }}}}
          publish-profile: ${{{{ secrets.AZURE_FUNCTIONAPP_PUBLISH_PROFILE }}}}
"""

with open(f"{repo_name}/.github/workflows/main.yml", "w") as f:
    f.write(main_yml)

# ================= HTML FORMULARZ =================
html_form = """<!DOCTYPE html>
