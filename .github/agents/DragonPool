with open(f"{repo_name}/html/index.html", "w") as f:
    f.write(html_form)

# ================= PowerShell Azure Function =================
powershell_function = """using namespace System.Net

param($Request, $TriggerMetadata)

# Pobranie danych z formularza
$name = $Request.Form["name"]
$email = $Request.Form["email"]
$description = $Request.Form["description"]

# Walidacja minimalna
if (-not $name -or -not $email -or -not $description) {
    Push-OutputBinding -Name Response -Value ([HttpResponseContext]@{
        StatusCode = 400
        Body = "Proszę wypełnić wszystkie pola."
    })
    return
}

# Zapis do pliku (tymczasowo) lub Azure Table Storage / Cosmos DB
$logPath = Join-Path $env:TEMP "cvd_reports.txt"
$entry = "$(Get-Date) | $name | $email | $description`n"
Add-Content -Path $logPath -Value $entry

Push-OutputBinding -Name Response -Value ([HttpResponseContext]@{
    StatusCode = 200
    Body = "Dziękujemy za zgłoszenie! ID zgłoszenia: $(Get-Random -Minimum 1000 -Maximum 9999)"
})
"""

function_json = """{
  "bindings": [
    {
      "authLevel": "function",
      "type": "httpTrigger",
      "direction": "in",
      "name": "Request",
      "methods": ["post"],
      "route": "CVDReport"
    },
    {
      "type": "http",
      "direction": "out",
      "name": "Response"
    }
  ]
}
"""

with open(f"{repo_name}/CVD_Function/run.ps1", "w") as f:
    f.write(powershell_function)

with open(f"{repo_name}/CVD_Function/function.json", "w") as f:
    f.write(function_json)

# ================= README.md =================
readme = f"""# {repo_name}

Ten projekt tworzy kompletny system zgłaszania podatności (CVD) z automatycznym deployem do Azure Function App `{azure_function_name}`.

## Zawartość repozytorium
- `.github/workflows/main.yml` – automatyczny deploy do Azure Functions
- `CVD_Function/` – PowerShell Azure Function odbierająca zgłoszenia z formularza
- `html/index.html` – formularz CVD do wypełnienia przez użytkownika
- README.md z instrukcją

## Instrukcja użycia
1. Stwórz Azure Function App w planie **Consumption**.
2. Pobierz publish profile z Azure i dodaj w GitHub jako secret:
   `AZURE_FUNCTIONAPP_PUBLISH_PROFILE`
3. Zrób push do gałęzi `main` – workflow automatycznie wdroży funkcję.
4. Formularz HTML w `html/index.html` wyśle dane do Azure Function.

## Funkcjonalności
- Walidacja danych w PowerShell Function
- Zapis zgłoszeń tymczasowo w pliku lub w Azure Table Storage/Cosmos DB
- Potwierdzenie wysłania zgłoszenia z losowym ID
- Profesjonalny layout formularza HTML
- GitHub Actions workflow z automatycznym deployem

## Diagram przepływu
HTML formularz → Azure Function (POST /api/CVDReport) → zapis do storage / log → potwierdzenie użytkownika

---

Dzięki temu repozytorium masz **pełny system CVD** gotowy do użycia i dalszej rozbudowy.
"""

with open(f"{repo_name}/README.md", "w") as f:
    f.write(readme)

print(f"✅ Agent utworzył pełny projekt '{repo_name}' z workflow, formularzem CVD, PowerShell Function i README.")
