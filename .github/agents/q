<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Ultra Repo AI Agent + MCP</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
body { font-family: Arial; margin:2rem; background:#f4f6f8; }
.section { background:white; padding:1rem; margin-bottom:1rem; border-radius:6px; }
button { padding:0.5rem 1rem; margin-top:0.5rem; cursor:pointer; }
input { padding:0.5rem; width:400px; }
</style>
</head>
<body>

<h1>🤖 Ultra Repo AI Agent + MCP</h1>

<input type="text" id="repoUrl" placeholder="https://github.com/user/repo">
<button onclick="loadRepo()">Załaduj repo</button>
<button onclick="toggleMode()">Zmień tryb agenta</button>

<div class="section">
<h2>Analiza Repo</h2>
<pre id="analysisOutput">Załaduj repo i kliknij analizę.</pre>
<button onclick="runAnalysis()">Rozpocznij analizę</button>
</div>

<div class="section">
<h2>Decyzja Agenta</h2>
<pre id="decisionOutput"></pre>
</div>

<div class="section">
<h2>Scoring</h2>
<canvas id="scoreChart" width="400" height="200"></canvas>
</div>

<div class="section">
<button onclick="showPR()">Generuj Pull Request</button>
</div>

<script>
// =========================
// GLOBAL STATE
// =========================
let repoFiles = [];
let securityIssues = ['Brak walidacji inputu'];
let refactorSuggestions = ['Monolit w app.js'];
let history = JSON.parse(localStorage.getItem("agentHistory")) || [];
let scoreHistory = JSON.parse(localStorage.getItem("scoreHistory")) || [];
let agentMode = "calm";
let currentRisk = { level: "LOW", score: 0 };

// =========================
// MCP CONFIGURATION
// =========================
const MCP_CONFIG = {
  "mcpServers": {
    "sentry": {
      "type": "local",
      "command": "npx",
      "args": ["@sentry/mcp-server@latest", "--host=$SENTRY_HOST"],
      "tools": ["get_issue_details", "get_issue_summary"],
      "env": {
        "SENTRY_HOST": "COPILOT_MCP_SENTRY_HOST",
        "SENTRY_ACCESS_TOKEN": "COPILOT_MCP_SENTRY_ACCESS_TOKEN"
      }
    },
    "notionApi": {
      "type": "local",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "-e",
        "OPENAPI_MCP_HEADERS={\"Authorization\": \"Bearer $NOTION_API_KEY\", \"Notion-Version\": \"2022-06-28\"}",
        "mcp/notion"
      ],
      "tools": ["*"],
      "env": { "NOTION_API_KEY": "COPILOT_MCP_NOTION_API_KEY" }
    },
    "azure": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@azure/mcp@latest", "server", "start"],
      "tools": ["*"]
    },
    "cloudflare": {
      "type": "sse",
      "url": "https://docs.mcp.cloudflare.com/sse",
      "tools": ["*"]
    },
    "ado": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@azure-devops/mcp", "<org>", "-a", "azcli"],
      "tools": ["wit_get_work_item","wit_get_work_items_batch_by_ids","pipelines_get","repos_get"]
    },
    "github-mcp-server": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/readonly",
      "tools": ["*"],
      "headers": { "X-MCP-Toolsets": "repos,issues,users,pull_requests,code_security,secret_protection,actions,web_search" }
    }
  }
};

// =========================
// GITHUB FETCH
// =========================
async function loadRepo() {
  const url = document.getElementById("repoUrl").value.trim();
  const parts = url.replace("https://github.com/", "").split("/");
  const owner = parts[0];
  const repo = parts[1];
  try {
    const response = await fetch(`https://api.github.com/repos/${owner}/${repo}/contents`);
    const data = await response.json();
    if (Array.isArray(data)) {
      repoFiles = data.map(f => f.name);
      alert("Repo załadowane ✅");
    } else alert("Nie udało się pobrać repo");
  } catch { alert("Błąd połączenia z GitHub API"); }
}

// =========================
// DEEP SCAN
// =========================
function deepRepoScan() {
  const findings = [];
  const required = ['.gitignore','.env','package.json','.eslintrc'];
  required.forEach(f => { if(!repoFiles.includes(f)) findings.push(`Brak pliku: ${f}`); });
  if(!repoFiles.some(f=>f.includes('test'))) findings.push("Brak testów");
  if(!repoFiles.includes('Dockerfile')) findings.push("Brak Dockerfile");
  return findings;
}

// =========================
// SECURITY ENGINE
// =========================
function securityRiskEngine() {
  let risk = securityIssues.length * 2;
  if(!repoFiles.includes('.env')) risk += 2;
  if(!repoFiles.includes('.gitignore')) risk += 1;
  if(risk >=6) return { level:"HIGH", score:risk };
  if(risk >=3) return { level:"MEDIUM", score:risk };
  return { level:"LOW", score:risk };
}

// =========================
// MATURITY
// =========================
function repoMaturityLevel() {
  let score=0;
  if(repoFiles.includes('Dockerfile')) score+=2;
  if(repoFiles.some(f=>f.includes('test'))) score+=2;
  if(repoFiles.includes('.gitignore')) score+=1;
  if(repoFiles.includes('package.json')) score+=1;
  if(score<=2) return "PROTOTYPE 🚧";
  if(score<=4) return "STARTUP 🚀";
  if(score<=5) return "GROWTH 📈";
  return "ENTERPRISE 🏢";
}

// =========================
// CONFIDENCE
// =========================
function aiConfidence() {
  const issues = securityIssues.length + deepRepoScan().length;
  return Math.max(100 - issues*7, 40);
}

// =========================
// ROADMAP
// =========================
function generateDynamicRoadmap(){
  const steps=[];
  if(securityIssues.length>0) steps.push("Napraw security issues");
  deepRepoScan().forEach(f=>steps.push(`Rozwiąż: ${f}`));
  return steps;
}

// =========================
// ANALYSIS
// =========================
function runAnalysis(){
  const out=document.getElementById("analysisOutput");
  let output="📂 Repo Files:\n";
  repoFiles.forEach(f=>output+=`- ${f}\n`);
  const findings=deepRepoScan();
  output+="\n🧠 Deep Scan:\n";
  findings.forEach(f=>output+=`- ${f}\n`);
  currentRisk=securityRiskEngine();
  output+=`\n🔐 Security Risk: ${currentRisk.level} (${currentRisk.score})\n`;
  output+=`\n🏢 Maturity: ${repoMaturityLevel()}\n`;
  output+=`\n🧠 AI Confidence: ${aiConfidence()}%\n`;
  const productionReady =
    repoFiles.includes('Dockerfile') &&
    repoFiles.some(f=>f.includes('test')) &&
    securityIssues.length===0;
  output+=`\n🚀 Production Status: ${productionReady?"READY ✅":"NOT READY ❌"}\n`;
  output+="\n🗺 Roadmap:\n";
  generateDynamicRoadmap().forEach((r,i)=>{ output+=`${i+1}. ${r}\n`; });
  out.textContent=output;
  saveScoreTrend(aiConfidence());
  drawChart();
  runDecisionMaking();
}

// =========================
// DECISION ENGINE
// =========================
function runDecisionMaking(){
  let recommendation;
  if(currentRisk.level==="HIGH") recommendation="Napraw SECURITY NATYCHMIAST";
  else if(refactorSuggestions.length>0) recommendation="Zrób refaktoryzację";
  else recommendation="Dodaj CI/CD i testy";
  if(agentMode==="aggressive") recommendation="⚠️ PRIORYTET: "+recommendation.toUpperCase();
  history.push(recommendation);
  localStorage.setItem("agentHistory",JSON.stringify(history));
  document.getElementById("decisionOutput").textContent=
    `🤖 ${recommendation}\n\n📜 Historia:\n`+
    history.map((h,i)=>`${i+1}. ${h}`).join("\n");
}

// =========================
// PR GENERATOR
// =========================
function generatePullRequest(){
  let pr="### 🤖 AI Repo Improvements\n\n";
  generateDynamicRoadmap().forEach(s=>pr+=`- ${s}\n`);
  pr+=`\nConfidence: ${aiConfidence()}%`;
  return pr;
}
function showPR(){ alert(generatePullRequest()); }

// =========================
// MODE
// =========================
function toggleMode(){ agentMode=agentMode==="calm"?"aggressive":"calm"; alert("Tryb: "+agentMode); }

// =========================
// TREND & CHART
// =========================
function saveScoreTrend(score){ scoreHistory.push(score); localStorage.setItem("scoreHistory",JSON.stringify(scoreHistory)); }
function drawChart(){
  const ctx=document.getElementById('scoreChart');
  new Chart(ctx,{
    type:'bar',
    data:{ labels:['AI Confidence'], datasets:[{ label:'AI Confidence', data:[aiConfidence()] }] }
  });
}
</script>
</body>
</html>
