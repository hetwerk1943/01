# Ultra Security Monitor – Environment Configuration
# Copy this file to .env.local and fill in your actual values.
# Do NOT commit .env.local to version control.

# Application settings
APP_NAME=Ultra-Security-Monitor
APP_ENV=development
APP_PORT=3000

# SIEM integration (optional)
SIEM_API_URL=https://your-siem-instance/api
SIEM_API_KEY=your_api_key_here

# Logging
LOG_LEVEL=info
LOG_PATH=./logs/security.log
