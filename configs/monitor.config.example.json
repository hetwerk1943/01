{
  "_comment": "Copy this file to monitor.config.json inside your BaseFolder and customise.",
  "BaseFolder": "%USERPROFILE%\\Documents\\SecurityMonitor",
  "MaxLogSizeMB": 50,
  "MaxDiscordMsgLength": 2000,
  "DiscordWebhookUrl": "",
  "VirusTotalApiKey": "",
  "EmailAlerts": false,
  "SmtpServer": "",
  "SmtpFrom": "",
  "SmtpTo": "",
  "SmtpUseSsl": true,
  "SmtpPort": 587,
  "MonitoredFolders": [
    "%WINDIR%\\System32",
    "%ProgramFiles%",
    "%ProgramFiles(x86)%",
    "%USERPROFILE%\\Documents",
    "%USERPROFILE%\\Desktop"
  ],
  "SuspiciousNames": [
    "wscript.exe",
    "cscript.exe",
    "mshta.exe",
    "rundll32.exe",
    "pwsh.exe",
    "cmd.exe"
  ],
  "SuspiciousPathPatterns": [
    "*\\AppData\\Local\\Temp\\*",
    "*\\Temp\\*",
    "*\\AppData\\Roaming\\*"
  ],
  "DefaultWhitelist": [
    "%WINDIR%\\*",
    "%ProgramFiles%\\*",
    "%ProgramFiles(x86)%\\*",
    "*\\OneDrive\\*",
    "*\\Steam\\*",
    "*\\ProtonVPN\\*"
  ]
}
